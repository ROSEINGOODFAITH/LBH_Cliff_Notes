# ============================================================================
# LBH CLIFF NOTES — environment variables
# Copy to `.env.local` for development. NEVER commit a filled-in copy.
# All keys below are server-only EXCEPT NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY.
# ============================================================================

# ---- Database: Neon Postgres ----
# Pooled connection string for the app (…-pooler.neon.tech). Use the *direct*
# (non-pooled) URL for drizzle-kit migrations if pooling causes issues.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/lbh?sslmode=require"

# ---- Auth: Clerk (single-team, no public signup) ----
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxx"
CLERK_SECRET_KEY="sk_test_xxx"
# Optional: keep sign-in on a single route
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/"

# ---- AI: Anthropic (generation + classification) — needed from P2 ----
ANTHROPIC_API_KEY="sk-ant-xxx"

# ---- Creator data: Modash (LOCKED) — needed from P1 ----
# Discovery shows an empty state until this is set; nothing is faked.
MODASH_API_KEY="xxx"

# ---- Commerce: Shopify Admin API ----
# Confirmed live store: www.laurelbathhouse.com
SHOPIFY_STORE_DOMAIN="laurelbathhouse.myshopify.com"
SHOPIFY_ADMIN_TOKEN="shpat_xxx"
SHOPIFY_API_VERSION="2025-10"

# ---- Email: Gmail API (send + receive) — needed from P2 ----
# OAuth client from Google Cloud Console with gmail.send + gmail.readonly scopes.
GMAIL_CLIENT_ID="xxx.apps.googleusercontent.com"
GMAIL_CLIENT_SECRET="xxx"
GMAIL_REFRESH_TOKEN="xxx"
GMAIL_SENDER="outreach@laurelbathhouse.com"

# ---- Background jobs: Inngest — needed from P2 ----
INNGEST_EVENT_KEY="xxx"
INNGEST_SIGNING_KEY="signkey-xxx"

# ---- PULSE campaign module ----
# Smartlead cold-email sequences (Tier A = paid review, Tier B = gift + affiliate)
SMARTLEAD_API_KEY="xxx"
SMARTLEAD_CAMPAIGN_TIER_A="xxx"
SMARTLEAD_CAMPAIGN_TIER_B="xxx"
SMARTLEAD_WEBHOOK_SECRET="xxx"
# Tally intake webhook signing reuses TALLY_SIGNING_SECRET above
TALLY_SIGNING_SECRET="xxx"
TALLY_FORM_URL="https://tally.so/r/rj1jqp"
CREATIVE_BRIEF_URL="https://…"
# Shopify variant shipped as the PULSE seeding unit
PULSE_SEEDING_VARIANT_ID="xxx"
# Set to 1 to run the whole pipeline against mocks (zero external keys needed)
MOCK="0"
